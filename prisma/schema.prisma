generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Statement {
  id                    String   @id @default(uuid())
  borrowerId            String?
  accountNumber         String?
  fileName              String?
  fileUrl               String?
  score                 Int?
  decision              String?
  createdAt             DateTime @default(now())

  transactions   Transaction[]
  feature        Feature?
}

model Transaction {
  id                   String   @id @default(uuid())
  statementId          String
  borrowerId           String?
  accountNumber        String?
  transactionDate      String
  transactionReference String?
  description          String
  debit                Float?
  credit               Float?
  category             String?

  statement Statement @relation(fields: [statementId], references: [id])
}

model Feature {
  statementId         String   @id
  avgIncome           Float?
  totalDebit          Float?
  avgBalance          Float?
  negativeBalanceDays Int?
  bounceCount         Int?

  statement Statement @relation(fields: [statementId], references: [id])
}

model Borrower {
  id        Int     @id @default(autoincrement()) @map("id")
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  email     String  @unique @map("email")
  phone     String  @map("phone")
  password  String  @map("password")
  otp       String? @map("otp")
  otpExpiresAt DateTime? @map("otp_expires_at")
  verified  Boolean? @default(false) @map("verified")
  createdAt DateTime @default(now()) @map("created_at")

  identities BorrowerIdentity[]

  @@map("borrowers")
}

model BorrowerIdentity {
  id                Int     @id @default(autoincrement()) @map("id")
  borrowerId        Int     @map("borrower_id")
  bvnNin            String  @map("bvn_nin")
  dob               DateTime @map("dob")
  mothersMaidenName String  @map("mothers_maiden_name")
  verified          Boolean @default(false) @map("verified")
  createdAt         DateTime @default(now()) @map("created_at")

  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)

  @@map("borrower_identities")
  @@index([borrowerId])
}
