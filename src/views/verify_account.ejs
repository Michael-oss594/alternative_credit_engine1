<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Verified</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #56ab2f 0%, #a8e6cf 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }
        .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 10px 10px; }
        .success-icon { font-size: 60px; color: #27ae60; }
        .btn { background: #56ab2f; color: white; padding: 15px 30px; text-decoration: none; border-radius: 5px; display: inline-block; font-weight: bold; }
        .features { background: white; padding: 20px; border-radius: 10px; margin: 20px 0; }
        .footer { text-align: center; margin-top: 30px; font-size: 12px; color: #666; }
    </style>
</head>
<body>
    <div class="header">
        <div class="success-icon"></div>
        <h1>Account Verified!</h1>
        <p>Welcome to Alternative Credit Engine, <%= firstName %>!</p>
    </div>
    
    <div class="content">
        <h2>Your account is ready!</h2>
        
        <div class="features">
            <h3>What you can do now:</h3>
            <ul>
                <li>Upload bank statements</li>
                <li>Get instant credit scores</li>
                <li>Access credit recommendations</li>
            </ul>
        </div>
        
        <p><a href="#" class="btn">Get Started Now</a></p>
        
        <hr>
        <p>Best regards,<br><strong>Alternative Credit Engine Team</strong></p>
    </div>
    
    <div class="footer">
        <p>© 2026 Alternative Credit Engine. All rights reserved.</p>
    </div>
</body>
</html>
