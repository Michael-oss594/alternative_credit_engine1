{
  "version": 2,
  "routes": [
    { "src": "/(.*)", "dest": "app.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://freshpee78.github.io, http://localhost:5500" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, application/json" },
        { "key": "Access-Control-Allow-Credentials", "value": "false" }
      ]
    }
  ],
  "functions": {
    "app.js": {
      "maxDuration": 30
    }
  }
}
